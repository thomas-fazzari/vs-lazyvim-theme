  "tokenColors": [
    {
      "scope": [
        "*"
      ],
      "settings": {
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier",
        "constant.language"
      ],
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python",
        "keyword.operator.wordlike"
      ],
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#2AC3DE"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#73DACA"
      }
    },
    {
      "scope": [
        "entity.name.namespace",
        "entity.name.type.namespace"
      ],
      "settings": {
        "foreground": "#2AC3DE"
      }
    },
    {
      "scope": [
        "entity.name.type.parameter"
      ],
      "settings": {
        "foreground": "#89DCEB"
      }
    },
    {
      "scope": [
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#4EC9B0"
      }
    },
    {
      "scope": [
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#9ECE6A"
      }
    },
    {
      "scope": [
        "entity.name.type.struct"
      ],
      "settings": {
        "foreground": "#73DACA"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "entity.name.function.extension"
      ],
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "scope": [
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#BB9AF7"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "support.variable",
        "entity.name.variable",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#C0CAF5"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#A9B1F7"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "entity.name.variable.field"
      ],
      "settings": {
        "foreground": "#73DACA"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#A9B1F7"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#9ECE6A"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#89DCEB"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#A9B1F7"
      }
    },
    {
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "scope": [
        "source"
      ],
      "settings": {
        "foreground": "#C0CAF5"
      }
    },
    {
      "scope": [
        "comment",
        "comment.line",
        "comment.block"
      ],
      "settings": {
        "foreground": "#636DA6"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#F7768E"
      }
    },
    {
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#7DCFFF"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#7AA2F7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {}
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#9ECE6A"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#F7768E"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#A9B1F7"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#73DACA"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#9ECE6A"
      }
    },
    {
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#7DCFFF"
      }
    }
  ],
